// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MarketType {
  LIMIT
  MARKET
}

enum Side {
  BUY
  SELL
}

enum Status {
  OPEN
  FILLED
  PARTIALLY_FILLED
  CANCELLED
}

model User{
  id        String  @id @default(uuid())
  username  String  @unique
  password  String

  orders    Order[]
  buyFills  Fill[]  @relation("FillBuyer")
  sellFills Fill[]  @relation("FillSeller")
}

model Order{
  id        String   @id @default(uuid())
  userId    String 
  symbol    String
  price     Int
  qty       Int
  type      MarketType 
  side      Side
  filledQty Float
  status    Status
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  buyFills  Fill[]   @relation("BuyOrder")
  sellFills Fill[]   @relation("SellOrder")

  market    Market   @relation(fields: [symbol], references: [symbol])

}

model Fill{
  id          String   @id @default(uuid())
  symbol      String
  price       Int
  qty         Int
  side        Side
  buyOrderId  String
  sellOrderId String
  buyerId     String
  sellerId    String
  createdAt   DateTime @default(now())

  buyOrder    Order    @relation("BuyOrder", fields: [buyOrderId], references: [id])
  sellOrder   Order    @relation("SellOrder", fields: [sellOrderId], references: [id])

  buyer       User     @relation("FillBuyer",fields: [buyerId], references: [id])
  seller      User     @relation("FillSeller",fields: [sellerId], references: [id])

  market      Market   @relation(fields: [symbol], references: [symbol])
}

model Market {
  id      String  @id @default(uuid())
  name    String
  symbol  String  @unique

  order Order[]
  fills Fill[]
}

